<!DOCTYPE html>
<html lang="en" data-theme="dark">
    <head>
        <title></title>
        <script src="https://cdn.jsdelivr.net/npm/markdown-wasm@1.2.0/dist/markdown.min.js"></script>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2.1.1/css/pico.min.css">
        <style>
            :root {
            /* Palette adjusted for the hero image colors */
                --primary: #38bdf8;
                --primary-hover: #0ea5e9;
                --background-color: #0f172a;
                --card-background-color: #1e293b;
                --color: #f1f5f9;
                --font-family: 'Inter', system-ui, -apple-system, sans-serif;
            }

            body {
                background-color: var(--background-color);
                color: var(--color);
                font-family: var(--font-family);
            }

        /* Wider container requested by user */
            @media (min-width: 992px) {
                .container {
                    max-width: 1100px;
                }
            }

            nav {
                padding: 1rem 0;
                border-bottom: 1px solid #1e293b;
                margin-bottom: 2rem;
            }

            nav strong {
                font-size: 1.5rem;
                background: linear-gradient(to right, #38bdf8, #818cf8);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        /* Hero Section Refactor */
            .hero-section {
                display: grid;
                grid-template-columns: 1fr;
                gap: 2rem;
                align-items: center;
                padding: 3rem 0 5rem;
            }

            @media (min-width: 768px) {
                .hero-section {
                    grid-template-columns: 1fr 1fr;
                    text-align: left;
                }
            }

            .hero-text h1 {
                font-size: clamp(2.5rem, 5vw, 4rem);
                line-height: 1.1;
                margin-bottom: 1.5rem;
                font-weight: 800;
            }

            .hero-text p {
                font-size: 1.25rem;
                color: #94a3b8;
                margin-bottom: 2rem;
            }

            .hero-image-container {
                position: relative;
                border-radius: 24px;
                overflow: hidden;
            //box-shadow: 0 0 50px rgba(56, 189, 248, 0.15);
                transition: transform 0.3s ease;
            }

            .hero-image-container:hover {
                transform: scale(1.02);
            }

            .hero-image-container img {
                display: block;
                width: 100%;
                height: auto;
            }

        /* Features Styling */
            .feature-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
                gap: 1.5rem;
                margin: 4rem 0;
            }

            .feature-card {
                background: var(--card-background-color);
                padding: 2.5rem;
                border-radius: 20px;
                border: 1px solid #334155;
                transition: all 0.3s ease;
            }

            .feature-card:hover {
                border-color: var(--primary);
                background: #253145;
            }

            .icon-box {
                color: var(--primary);
                margin-bottom: 1.5rem;
            }

        /* Login Section */
            .login-section {
                background: radial-gradient(circle at center, #1e293b, #0f172a);
                padding: 4rem 2rem;
                border-radius: 24px;
                border: 1px solid #334155;
                text-align: center;
                margin: 5rem 0;
            }

            .social-btn {
                display: inline-flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.75rem 2rem;
                background: #24a1de; /* Telegram blue */
                border: none;
                border-radius: 12px;
                color: white;
                font-weight: 700;
                text-decoration: none;
            }

            footer {
                padding: 3rem 0;
                text-align: center;
                border-top: 1px solid #1e293b;
                color: #64748b;
            }

            .accent-text {
                color: var(--primary);
            }
        </style>
        <style>
            @media (min-width: 1200px) {
                :root {
                    font-size: 18px;
          /* Limits global scaling */
                }
            }

            @media (min-width: 768px) {
                .container {
                    max-width: 768px;
                }
            }
        </style>
    </head>
    <body>
        <div class="container">
            <nav class="container">
                <ul>
                    <li><strong>name</strong></li>
                </ul>
                <ul>
                    <li><a href="/#features" class="secondary">Features</a></li>
                    <li><a href="/#login" role="button">Join Now</a></li>
                </ul>
            </nav>
            <div id="content" class="container">
                {% block content %}
                {% endblock content %}
            </div>
            <footer class="container">
                <p><small>© Name </small></p>
                <p><small><a href="/terms">Terms&amp;Conditions</a> <a href="/privacy">Privacy policy</a></small></p>
            </footer>
        </div>
        <!--script>
            window["markdown"].ready.then(markdown => {
                const content = document.getElementById("content");
                content.innerHTML = markdown.parse({{ content | tojson | safe }});
            })
        </script-->
    </body>
</html>
